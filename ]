    fn load_text_document(access_info: &DbAccessInfo, doc_id: &str) -> DocContent {
        let cmd = Command::Storage(StorageCommand::Get(Get {
            key: BulkString::from(doc_id),
        }));

        let content = match client::send_command(cmd, access_info.addr).unwrap() {
            RespDataType::BulkString(content) => content.to_string(),
            RespDataType::Null => "".to_string(),
            _ => todo!(),
        };

        DocContent::Text(content)
    }

    fn load_spreadsheet_document(access_info: &DbAccessInfo, doc_id: &str) -> DocContent {
        let cmd = Command::Storage(StorageCommand::HGetAll(HGetAll {
            key: BulkString::from(doc_id),
        }));

        let content = match client::send_command(cmd, access_info.addr).unwrap() {
            RespDataType::Map(content) => {
                print!("{}", log::info!("cargando planilla de cálculo existente"));

                let mut parsed_content = [[0; 10]; 10];

                for (i, v) in content {
                    let (i, v) = match (i, v) {
                        (RespDataType::BulkString(i), RespDataType::BulkString(v)) => {
                            (i.to_string(), v.to_string())
                        }
                        _ => panic!("Formato inesperado en el mapa de Redis"),
                    };

                    let (fil, col) = i.split_once(',').unwrap();
                    let fil: usize = fil.parse().unwrap();
                    let col: usize = col.parse().unwrap();

                    let v: i64 = v.parse().unwrap();

                    parsed_content[fil][col] = v;
                }

                parsed_content
            }
            RespDataType::Null => {
                print!("{}", log::info!("inicializando nueva planilla de cálculo"));
                [[0; 10]; 10]
            }
            _ => todo!(),
        };

        DocContent::SpreadSheet(content)
    }

