    pub fn ui(&mut self, ui: &mut egui::Ui) -> bool {
        let mut stay_in_editor = true;

        if ui.link("⬅️ Volver").clicked() {
            stay_in_editor = false;
        };

        match &mut self.doc_content {
            DocContent::Text(content) => {
                ui.add(TextEditor { content });
            }
            DocContent::SpreadSheet(content) => {
                let mut content: DataTable<SpreadSheetRow> =
                    content.into_iter().map(|r| SpreadSheetRow(*r)).collect();
                ui.add(Renderer::new(&mut content, &mut { SpreadSheetRowViewer }));
            }
        };

        if ui.button("Guardar ✅").clicked() {
            self.save_document();
        }

        stay_in_editor
    }
}
