#[derive(Debug)]
pub struct Editor {
    access_info: DbAccessInfo,
    doc_metadata: DocMetadata,
    doc_content: DocContent,
}

impl Editor {
    pub fn new(access_info: DbAccessInfo, doc_metadata: DocMetadata) -> Self {
        print!("{}", log::info!("accediendo documento {}", doc_metadata.id));

        Self::subscribe_to_document(&access_info, doc_id);

        let doc_content = match doc_metadata.kind {
            DocKind::Text => Self::load_text_document(&access_info, &doc_metadata.id),
            DocKind::SpreadSheet => Self::load_spreadsheet_document(&access_info, &doc_metadata.id),
        };

        Self {
            access_info,
            doc_metadata,
            doc_content,
        }
    }

    fn subscribe_to_document(access_info: &DbAccessInfo, doc_id: &str) {
        let cmd = Command::PubSub(PubSubCommand::Subscribe(Subscribe {
            channels: vec![doc_id.into()],
        }));

        let mut editor_stream = TcpStream::connect(access_info.addr).unwrap();
        editor_stream.write_all(&Vec::from(cmd)).unwrap();

        thread::spawn(move || {
            let mut buffer = BufReader::new(&mut editor_stream);

            loop {
            }
        });
    }

    fn fetch_document(&mut self, doc_id: &str) {
